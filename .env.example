# Copy to .env and fill in your keys

# Anthropic — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE


# Model to use
# claude-haiku-4-5-20251001  (~$0.002/order, ~600ms)
# claude-sonnet-4-6           (~$0.015/order, ~1200ms) ← default
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Stripe — test mode keys from https://dashboard.stripe.com/test/apikeys
# Test card: 4242 4242 4242 4242 · any future MM/YY · any 3-digit CVC
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE

# Inventory admin page password
# Gates ui/pages/1_Inventory.py — without this, the admin page is hard-locked
# and shows "admin disabled". Set to any non-empty string. Case-sensitive,
# whitespace matters. Use a strong secret in production.
ADMIN_PASSWORD=change-me-to-a-strong-secret

# Gmail receipt emails (optional)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords → create an app password
# 3. Fill in below — receipts are skipped silently if these are missing
GMAIL_SENDER=your-email@example.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Override DB path if needed (default: data/menu.db)
# MENU_DB_PATH=/path/to/menu.db
